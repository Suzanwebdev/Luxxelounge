# =============================================================================
# Local development — copy this file to ".env.local" (same folder as package.json)
# then paste your keys. Next.js loads .env.local automatically; restart `npm run dev` after changes.
# Supabase path: Dashboard → your project → Project Settings → API
# =============================================================================

# Project URL (Project URL field)
NEXT_PUBLIC_SUPABASE_URL=

# Paste the ANON / PUBLIC key here (labeled "anon" "public" in Supabase — safe to expose via NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional but recommended: SERVICE ROLE key (server-only). Used for admin category sync and guest orders.
# Never prefix with NEXT_PUBLIC_ — do not commit .env.local to git.
SUPABASE_SERVICE_ROLE_KEY=
