# =============================================================================
# Local development — copy THIS file to ".env.local" (same folder as package.json),
# then replace every placeholder with your real values (same keys as .env.example).
# Restart `npm run dev` after saving.
# =============================================================================

# --- Supabase (required) — Dashboard → Project Settings → API ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Server-only — not exposed to the browser. Required for: guest checkout orders, admin category sync,
# payment initiate when reading guest orders. Optional for read-only storefront if you use anon only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Site / email (optional) ---
RESEND_API_KEY=
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- Payments (optional; mock mode if unset) ---
MOOLRE_API_URL=
MOOLRE_API_KEY=
MOOLRE_SECRET=
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=

# --- App URLs — local: http://localhost:3000 | Vercel: https://your-domain.vercel.app ---
APP_BASE_URL=
NEXT_PUBLIC_APP_BASE_URL=
