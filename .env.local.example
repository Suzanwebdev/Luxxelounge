# =============================================================================
# Local development — copy this file to ".env.local" (same folder as package.json).
# Then paste your keys from Supabase → Project Settings → API.
# Restart `npm run dev` after any change.
# =============================================================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — paste "service_role" secret (keep out of git and never NEXT_PUBLIC_*)
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: same as .env.example for email, WhatsApp, payments, URLs ---
# RESEND_API_KEY=
# NEXT_PUBLIC_WHATSAPP_NUMBER=
# APP_BASE_URL=http://localhost:3000
