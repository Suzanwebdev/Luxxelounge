# =============================================================================
# Environment template (safe to commit — use placeholders only, never real secrets).
#
# Local:  copy this file to ".env.local" OR copy ".env.local.example" → same keys, then replace
#         placeholders with your Supabase URL, anon key, and service_role key. Restart `npm run dev`.
# Vercel: Project → Settings → Environment Variables — same names and real values as .env.local.
# =============================================================================

# --- Supabase (required) — Dashboard → Project Settings → API ---
# Must be the Supabase project URL (…supabase.co). Do NOT put it in NEXT_PUBLIC_APP_BASE_URL — that is your storefront URL.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Server-only — not exposed to the browser. Required for: guest checkout orders, admin category sync,
# payment initiate when reading guest orders. Optional for read-only storefront if you use anon only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Site / email (optional) ---
RESEND_API_KEY=
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- Payments (optional; mock mode if unset) ---
MOOLRE_API_URL=
MOOLRE_API_KEY=
MOOLRE_SECRET=
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=

# --- App URLs — Vercel: set APP_BASE_URL to https://your-domain.vercel.app for payment redirects ---
APP_BASE_URL=
NEXT_PUBLIC_APP_BASE_URL=
