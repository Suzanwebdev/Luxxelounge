# Copy to ".env.local" for real values — do not put production secrets in this file (it is committed to git).
# Use ".env.local.example" as a starting point, or Supabase → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key
# Server-only — never use NEXT_PUBLIC_ for this. Needed for admin category sync and guest checkout APIs.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

RESEND_API_KEY=
MOOLRE_API_KEY=
MOOLRE_SECRET=
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
# Payment return URLs; on Vercel set APP_BASE_URL to https://your-domain.vercel.app (or omit and the app uses the request origin).
APP_BASE_URL=
NEXT_PUBLIC_APP_BASE_URL=
NEXT_PUBLIC_WHATSAPP_NUMBER=233276332484
